# =============================================================================
# FNF Mod Sync Tool — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
#   cp scripts/.env.example scripts/.env
# NEVER commit .env to version control.
# =============================================================================

# --- GitHub Personal Access Token (classic, with repo scope) ----------------
# Generate at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_your_token_here

# --- GameBanana API Key (optional for reads, required for writes) -----------
# The Core API at api.gamebanana.com does not require a key for read
# operations.  File uploads and update posts require a session token below.
GAMEBANANA_API_KEY=your_gamebanana_api_key

# --- GameBanana Session Token (required for file uploads & update posts) ----
# This is the PHPSESSID cookie value from a logged-in GameBanana session.
# To get it:
#   1. Log in to GameBanana in your browser
#   2. Open DevTools → Application → Cookies → gamebanana.com → PHPSESSID
#   3. Copy the value here
GAMEBANANA_SESSION_TOKEN=your_phpsessid_here
